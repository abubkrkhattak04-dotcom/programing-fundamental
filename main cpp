void studentMenu(){
  int ch;
  do{
    cout << "\n--- Student Operations ---" << endl;
    cout << "1. Add Student" << endl;
    cout << "2. Search by Roll" << endl;
    cout << "3. Search by Name" << endl;
    cout << "4. Update Student" << endl;
    cout << "5. Delete Student" << endl;
    cout << "6. List All" << endl;
    cout << "0. Back" << endl;
    cout << "Choice: ";
    cin >> ch;

    if (ch == 1)
      addStudent();
    else if (ch == 2) {
      string r;
      cout << "Roll: ";
      cin >> r;
      searchStudent(r);

    } else if (ch == 3) {
      string n;
      cout << "Name: ";
      cin.ignore();
      getline(cin, n);
      searchByName(n);
    } 
    else if (ch == 4) {
      string r;
      cout << "Roll: ";
      cin >> r;
      updateStudent(r);
    } 
    else if (ch == 5) {
      string r;
      cout << "Roll: ";
      cin >> r;
      deleteStudent(r);
    } 
    else if (ch == 6)
      listStudents();
  } while (ch != 0);
}

